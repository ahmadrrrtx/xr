{
  "name": "@rrrtx/xr",
  "version": "3.1.6",
  "description": "XR 3.1.6 (Baseline Integrity) \u2014 verified local-first AI runtime baseline with reproducible validation, diagnostics, support matrix, and release artifacts.",
  "type": "module",
  "bin": {
    "xr": "./bin/xr.cjs"
  },
  "files": [
    "bin",
    "src",
    "plugins",
    "skills",
    "assets",
    "docs",
    "README.md",
    "LICENSE",
    "install.sh",
    "install.ps1"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "ci": "bun run typecheck && bun test && bun run set-version:check && bun run baseline:inventory",
    "xr": "bun run src/index.ts",
    "cli:help": "bun run src/index.ts help",
    "cli:doctor": "bun run src/index.ts doctor",
    "set-version": "bun run scripts/set-version.ts",
    "set-version:check": "bun run scripts/set-version.ts --check",
    "prepublishOnly": "bun run scripts/set-version.ts --check",
    "baseline:inventory": "bun run scripts/baseline-inventory.ts",
    "baseline:measure": "bun run scripts/measure-baseline.ts",
    "baseline:validate": "bun run scripts/validate-baseline.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmadrrrtx/xr.git"
  },
  "bugs": {
    "url": "https://github.com/ahmadrrrtx/xr/issues"
  },
  "homepage": "https://xr-gules.vercel.app",
  "keywords": [
    "ai-agent",
    "ai-os",
    "byok",
    "local-llm",
    "ollama",
    "prompt-injection",
    "secure-agent",
    "cli",
    "rrtx"
  ],
  "author": "Muhammad Ahmad (@ahmadrrrtx)",
  "license": "MIT",
  "dependencies": {
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "playwright": "^1.47.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.14"
}
