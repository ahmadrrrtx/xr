{
  "compilerOptions": {
    "lib": ["ESNext"],
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["bun-types"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "//exclude": "tui2.ts is unfinished, unused scaffolding (the active TUI is tui.ts). Excluded from typecheck until it is wired up or removed.",
  "exclude": ["src/interfaces/tui2.ts"]
}
